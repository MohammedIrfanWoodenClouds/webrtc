{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "watchPatterns": [
            "/backend/**"
        ]
    },
    "deploy": {
        "startCommand": "cd backend && npm install && npm run build && npm start",
        "healthcheckPath": "/health",
        "healthcheckTimeout": 100,
        "restartPolicyType": "ON_FAILURE",
        "numReplicas": 1
    }
}